# Required
DATABASE_URL=sqlite:///data/podcast.db
AWS_ACCESS_KEY_ID=tid_...
AWS_SECRET_ACCESS_KEY=tsec_...
AWS_ENDPOINT_URL_S3=https://fly.storage.tigris.dev
AWS_REGION=auto
BUCKET_NAME=your-bucket-name
ANTHROPIC_API_KEY=sk-ant-...
ADMIN_TOKEN=your-admin-token

# Google API key (used for both Google TTS and Gemini image generation)
GOOGLE_API_KEY=...

# At least one TTS provider required
OPENAI_API_KEY=sk-...
ELEVENLABS_API_KEY=...
# Google TTS uses GOOGLE_API_KEY above

# Optional
ELEVENLABS_VOICE_ID=Rachel
OPENAI_TTS_VOICE=onyx
GOOGLE_TTS_VOICE=en-US-Journey-D
HOST=0.0.0.0
PORT=8080
PUBLIC_URL=https://your-app.fly.dev
WORKER_POLL_INTERVAL_SECS=5
MAX_JOB_ATTEMPTS=3
GENERATE_IMAGES=true
STATIC_DIR=../frontend/build
